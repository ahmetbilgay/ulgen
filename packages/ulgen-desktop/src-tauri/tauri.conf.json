{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ULGEN",
  "version": "0.1.0",
  "identifier": "io.ulgen.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "ULGEN",
        "width": 1600,
        "height": 960,
        "minWidth": 1240,
        "minHeight": 760,
        "transparent": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
